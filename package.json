{
  "name": "gomz-club-contracts",
  "version": "1.0.0",
  "private": true,
  "description": "Cleaned Hardhat repository for the GOMZ Club ERC721A-based NFT collection contract.",
  "scripts": {
    "node": "hardhat node",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "REPORT_COVERAGE=true npx hardhat coverage",
    "lint": "npm run lint:js && npm run lint:sol",
    "lint:js": "eslint --ignore-path .gitignore . --fix",
    "lint:sol": "prettier --write \"contracts/**/*.sol\" \"scripts/**/*.js\" \"test/**/*.js\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sueun-dev/gomz-club-contracts.git"
  },
  "keywords": [
    "erc721a",
    "ethereum",
    "hardhat",
    "nft",
    "gomz",
    "gomz-club"
  ],
  "author": "Sueun Cho",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sueun-dev/gomz-club-contracts/issues"
  },
  "homepage": "https://github.com/sueun-dev/gomz-club-contracts#readme",
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.6"
  },
  "devDependencies": {
    "@nomiclabs/hardhat-ethers": "^2.0.4",
    "@nomiclabs/hardhat-waffle": "^2.0.1",
    "@openzeppelin/test-helpers": "^0.5.15",
    "chai": "^4.3.4",
    "eslint": "^8.7.0",
    "eslint-plugin-mocha": "^10.0.3",
    "eslint-plugin-node": "^11.1.0",
    "ethereum-waffle": "^3.4.0",
    "ethers": "^5.5.3",
    "hardhat": "^2.8.2",
    "prettier": "^2.5.1",
    "prettier-plugin-solidity": "^1.0.0-beta.19",
    "solidity-coverage": "^0.7.20"
  }
}
